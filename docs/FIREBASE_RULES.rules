rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. PARENTS COLLECTION
    // Allow parents to read, insert and update only their own profile document
    match /parents/{parentId} {
      allow read, write: if request.auth != null && request.auth.uid == parentId;
    }
    
    // 2. CHILDREN COLLECTION
    // Allow parents to read, update or delete children profiles they own (matching parent_id field)
    match /children/{childId} {
      allow read, update, delete: if request.auth != null && resource.data.parent_id == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.parent_id == request.auth.uid;
    }
    
    // 3. PROGRESS COLLECTION
    // Allow parents to read or write the progress document of their own children
    // Verifies that the child's document exists and belongs to the current logged-in parent
    match /progress/{childId} {
      allow read, write: if request.auth != null && 
        exists(/databases/$(database)/documents/children/$(childId)) &&
        get(/databases/$(database)/documents/children/$(childId)).data.parent_id == request.auth.uid;
    }
  }
}
