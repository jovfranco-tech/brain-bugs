# Brain Bugs — Environment Variables
# Copy this file to .env.local — never commit .env.local

# ─── Firebase (optional) ──────────────────────────────────────────────────────
# Leave blank to use built-in localStorage mock auth (works out of the box).
# Set all to enable Firebase Auth + Firestore database persistence.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── App config ───────────────────────────────────────────────────────────────
VITE_APP_VERSION=0.3.0-mvp
VITE_APP_ENV=development

# ─── Feature flags (future) ───────────────────────────────────────────────────
# VITE_ENABLE_DAILY_CHALLENGE=false
# VITE_ENABLE_BUG_LAB=false
# VITE_ENABLE_AI_COACH=false
